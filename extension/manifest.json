{
  "manifest_version": 3,
  "name": "荧光手帐",
  "version": "0.1.2",
  "description": "把文章片段和你的想法保存到本地 Markdown 知识库。",
  "key": "",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "tabs", "sidePanel", "offscreen"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_title": "打开荧光手帐",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "save-selection": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "保存选中文字到荧光手帐"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
